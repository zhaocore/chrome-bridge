{
  "manifest_version": 3,
  "name": "ChromeBridge",
  "description": "A small TS/Vite browser bridge that accepts tool calls over WebSocket and executes them through Chrome DevTools Protocol.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/disconnected-16.png",
    "32": "icons/disconnected-32.png",
    "48": "icons/disconnected-48.png",
    "128": "icons/disconnected-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/disconnected-16.png",
      "32": "icons/disconnected-32.png",
      "48": "icons/disconnected-48.png",
      "128": "icons/disconnected-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "debugger",
    "storage",
    "alarms",
    "tabGroups",
    "windows"
  ],
  "host_permissions": ["<all_urls>"]
}
